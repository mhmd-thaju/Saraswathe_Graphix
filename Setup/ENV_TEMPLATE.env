# =============================================================
# PrintFlow ERP — Environment Variables Template
# File: ENV_TEMPLATE.env
# Instructions:
#   1. Copy this file to /backend/.env
#   2. Fill in your actual values
#   3. NEVER commit .env to version control
# =============================================================

# ----- Application -----
APP_ENV=development                   # development | production
APP_HOST=127.0.0.1
APP_PORT=8000
APP_SECRET_KEY=change-me-to-a-long-random-string-here

# ----- Database -----
SQLITE_DB_PATH=./printflow.db         # Path to SQLite database file

# ----- Supabase Cloud Backup -----
# Get these from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here   # Use SERVICE role, not anon

# ----- Backup Schedule -----
BACKUP_ENABLED=true
BACKUP_CRON_HOUR=2                    # Run backup at 2:00 AM daily
BACKUP_CRON_MINUTE=0

# ----- Shop Details (used in invoice generation) -----
SHOP_NAME=Saraswathe Graphix
SHOP_GSTIN=                           # Your 15-digit GSTIN e.g. 33XXXXX1234A1Z5
SHOP_ADDRESS=Your shop address here
SHOP_CITY=Chennai
SHOP_STATE=Tamil Nadu
SHOP_STATE_CODE=33                    # Tamil Nadu state code for GST
SHOP_MOBILE=9XXXXXXXXX
SHOP_EMAIL=your@email.com

# ----- CORS (Frontend URL) -----
FRONTEND_URL=http://localhost:5173
